{
	"name": "partyplayback",
	"compatibility_date": "2025-10-08",
	"compatibility_flags": ["nodejs_compat"],
	"main": "./dist/_worker.js/index.js",
	"assets": {
		"directory": "./dist",
		"binding": "ASSETS"
	},
	"observability": {
		"enabled": true
	},
	"upload_source_maps": true,
	"durable_objects": {
		"bindings": [
			{ "name": "ROOM", "class_name": "RoomDO" }
		]
	},
	"migrations": [
		{ "tag": "v1", "new_sqlite_classes": ["RoomDO"] }
	]
}
