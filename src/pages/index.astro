---
// Home page — room join / create UI
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>PartyPlayback — Watch Together</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <style>
    :root {
      --bg: #0d0d0f;
      --bg-surface: #18181b;
      --border: #3f3f46;
      --text: #fafafa;
      --text-muted: #a1a1aa;
      --accent: #6d28d9;
      --accent-light: #8b5cf6;
      --radius: 10px;
      --font: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    html, body {
      min-height: 100%;
      background: var(--bg);
      color: var(--text);
      font-family: var(--font);
      display: flex;
      flex-direction: column;
    }

    main {
      flex: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 2rem 1rem;
    }

    .logo {
      font-size: 2.5rem;
      font-weight: 800;
      letter-spacing: -0.03em;
      margin-bottom: 0.5rem;
      background: linear-gradient(135deg, var(--accent-light), #ec4899);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .tagline {
      color: var(--text-muted);
      font-size: 1rem;
      margin-bottom: 2.5rem;
    }

    .card {
      background: var(--bg-surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 2rem;
      width: 100%;
      max-width: 420px;
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }

    .card h2 {
      font-size: 0.85rem;
      font-weight: 600;
      color: var(--text-muted);
      text-transform: uppercase;
      letter-spacing: 0.06em;
    }

    .input-row {
      display: flex;
      gap: 0.5rem;
    }

    input[type="text"] {
      flex: 1;
      background: var(--bg);
      border: 1px solid var(--border);
      border-radius: 6px;
      color: var(--text);
      padding: 0.625rem 0.875rem;
      font-size: 0.95rem;
      font-family: var(--font);
      outline: none;
      transition: border-color 0.15s;
    }

    input[type="text"]:focus { border-color: var(--accent-light); }
    input[type="text"]::placeholder { color: var(--text-muted); }

    .btn-primary {
      background: var(--accent);
      color: #fff;
      border: none;
      border-radius: 6px;
      padding: 0.625rem 1.25rem;
      font-size: 0.95rem;
      font-weight: 600;
      cursor: pointer;
      font-family: var(--font);
      white-space: nowrap;
      transition: background 0.15s;
    }

    .btn-primary:hover { background: var(--accent-light); }

    .divider {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      color: var(--text-muted);
      font-size: 0.8rem;
    }

    .divider::before, .divider::after {
      content: "";
      flex: 1;
      height: 1px;
      background: var(--border);
    }

    .quick-rooms {
      display: flex;
      flex-wrap: wrap;
      gap: 0.4rem;
    }

    .quick-btn {
      background: var(--bg);
      border: 1px solid var(--border);
      color: var(--text-muted);
      border-radius: 6px;
      padding: 0.35rem 0.75rem;
      font-size: 0.825rem;
      cursor: pointer;
      font-family: var(--font);
      transition: border-color 0.15s, color 0.15s;
    }

    .quick-btn:hover {
      border-color: var(--accent-light);
      color: var(--accent-light);
    }

    footer {
      text-align: center;
      padding: 1.5rem;
      color: var(--text-muted);
      font-size: 0.8rem;
    }

    footer a { color: var(--text-muted); text-decoration: none; }
    footer a:hover { color: var(--text); }
  </style>
</head>
<body>
  <main>
    <div class="logo">PartyPlayback</div>
    <p class="tagline">Watch YouTube together, in sync.</p>

    <div class="card">
      <h2>Join or create a room</h2>
      <form id="room-form">
        <div class="input-row">
          <input
            type="text"
            id="room-input"
            placeholder="Room name..."
            autocomplete="off"
            spellcheck="false"
            maxlength="64"
          />
          <button class="btn-primary" type="submit">Join &rarr;</button>
        </div>
      </form>

      <div class="divider">or jump in</div>

      <div class="quick-rooms">
        <button class="quick-btn" data-room="general">general</button>
        <button class="quick-btn" data-room="music">music</button>
        <button class="quick-btn" data-room="movies">movies</button>
        <button class="quick-btn" data-room="gaming">gaming</button>
      </div>
    </div>
  </main>

  <footer>
    PartyPlayback &nbsp;&middot;&nbsp; <a href="/blog">Blog</a>
  </footer>

  <script>
    const form = document.getElementById('room-form');
    const input = document.getElementById('room-input');

    function goToRoom(name) {
      const slug = name.trim().toLowerCase().replace(/[^a-z0-9_-]/g, '-').replace(/-+/g, '-').replace(/^-|-$/g, '');
      if (slug) window.location.href = '/room/' + slug;
    }

    form.addEventListener('submit', (e) => {
      e.preventDefault();
      goToRoom(input.value);
    });

    document.querySelectorAll('.quick-btn').forEach(btn => {
      btn.addEventListener('click', () => goToRoom(btn.dataset.room));
    });
  </script>
</body>
</html>
