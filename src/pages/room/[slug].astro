---
const { slug } = Astro.params;

if (!slug || !/^[a-zA-Z0-9_-]{1,64}$/.test(slug)) {
  return Astro.redirect('/');
}

const roomName = slug;
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{roomName} — PartyPlayback</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <style>
    :root {
      --bg: #0d0d0f;
      --bg-surface: #18181b;
      --bg-hover: #27272a;
      --border: #3f3f46;
      --text: #fafafa;
      --text-muted: #a1a1aa;
      --accent: #6d28d9;
      --accent-light: #8b5cf6;
      --accent-dim: rgba(109, 40, 217, 0.12);
      --danger: #ef4444;
      --radius: 8px;
      --font: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      --sidebar: 320px;
      --header: 52px;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    html, body { height: 100%; background: var(--bg); color: var(--text); font-family: var(--font); font-size: 15px; }

    /* ---- Header ---- */
    #hdr {
      height: var(--header);
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 1rem;
      background: var(--bg-surface);
      border-bottom: 1px solid var(--border);
      position: sticky;
      top: 0;
      z-index: 10;
      gap: 0.5rem;
    }

    #hdr-left { display: flex; align-items: center; gap: 0.625rem; min-width: 0; }

    #hdr-back {
      color: var(--text-muted);
      text-decoration: none;
      font-size: 1.1rem;
      line-height: 1;
      flex-shrink: 0;
    }
    #hdr-back:hover { color: var(--text); }

    #hdr-room {
      font-size: 0.95rem;
      font-weight: 600;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    #hdr-right { display: flex; align-items: center; gap: 0.5rem; flex-shrink: 0; }

    #conn {
      font-size: 0.75rem;
      padding: 0.15rem 0.55rem;
      border-radius: 999px;
      border: 1px solid var(--border);
      display: flex;
      align-items: center;
      gap: 0.35rem;
      white-space: nowrap;
    }

    #conn::before {
      content: "";
      width: 7px;
      height: 7px;
      border-radius: 50%;
      background: var(--text-muted);
      flex-shrink: 0;
    }

    #conn.connected::before { background: #22c55e; }
    #conn.disconnected::before { background: var(--danger); }
    #conn.connecting::before { background: #f59e0b; animation: pulse 1s infinite; }

    @keyframes pulse { 0%,100% { opacity: 1; } 50% { opacity: 0.4; } }

    #uc {
      font-size: 0.75rem;
      color: var(--text-muted);
      background: var(--bg-hover);
      padding: 0.15rem 0.55rem;
      border-radius: 999px;
      border: 1px solid var(--border);
      white-space: nowrap;
    }

    #uname {
      font-size: 0.75rem;
      color: var(--accent-light);
      cursor: pointer;
      padding: 0.15rem 0.55rem;
      border-radius: 999px;
      border: 1px solid var(--accent);
      white-space: nowrap;
      max-width: 100px;
      overflow: hidden;
      text-overflow: ellipsis;
    }
    #uname:hover { background: var(--accent-dim); }

    /* ---- Body layout ---- */
    #body {
      display: flex;
      height: calc(100vh - var(--header));
      overflow: hidden;
    }

    /* ---- Player area ---- */
    #player-area {
      flex: 1;
      min-width: 0;
      display: flex;
      flex-direction: column;
      padding: 1rem;
      gap: 0.625rem;
      overflow-y: auto;
    }

    #player-wrap {
      width: 100%;
      aspect-ratio: 16 / 9;
      background: #000;
      border-radius: var(--radius);
      overflow: hidden;
      position: relative;
    }

    /* YouTube replaces #yt-player with an iframe; size it to fill the container */
    #yt-player { width: 100%; height: 100%; }

    #player-wrap iframe {
      position: absolute;
      inset: 0;
      width: 100% !important;
      height: 100% !important;
      border: none;
    }

    #placeholder {
      position: absolute;
      inset: 0;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 0.75rem;
      color: var(--text-muted);
      font-size: 0.875rem;
      background: #000;
      z-index: 1;
    }

    #placeholder svg { opacity: 0.3; }

    #nowplay {
      font-size: 0.875rem;
      color: var(--text-muted);
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
      padding: 0 0.125rem;
    }

    #nowplay b { color: var(--text); font-weight: 500; }

    /* ---- Queue sidebar ---- */
    #sidebar {
      width: var(--sidebar);
      flex-shrink: 0;
      display: flex;
      flex-direction: column;
      border-left: 1px solid var(--border);
      background: var(--bg-surface);
      overflow: hidden;
    }

    #q-header {
      padding: 0.75rem 1rem;
      border-bottom: 1px solid var(--border);
      font-size: 0.75rem;
      font-weight: 600;
      color: var(--text-muted);
      text-transform: uppercase;
      letter-spacing: 0.06em;
      flex-shrink: 0;
    }

    #q-list {
      list-style: none;
      flex: 1;
      overflow-y: auto;
      padding: 0.375rem 0;
    }

    #q-list:empty::after {
      content: "Queue is empty";
      display: block;
      text-align: center;
      padding: 2rem 1rem;
      color: var(--text-muted);
      font-size: 0.875rem;
    }

    .qi {
      display: flex;
      align-items: center;
      gap: 0.625rem;
      padding: 0.4rem 0.875rem;
      cursor: default;
      transition: background 0.1s;
    }
    .qi:hover { background: var(--bg-hover); }

    .qi.now {
      background: var(--accent-dim);
      border-left: 3px solid var(--accent-light);
      padding-left: calc(0.875rem - 3px);
    }

    .qi-thumb {
      width: 64px;
      height: 36px;
      object-fit: cover;
      border-radius: 4px;
      flex-shrink: 0;
      background: var(--bg-hover);
    }

    .qi-info { flex: 1; min-width: 0; }

    .qi-title {
      font-size: 0.8rem;
      font-weight: 500;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .qi-sub {
      font-size: 0.7rem;
      color: var(--text-muted);
      margin-top: 1px;
    }

    .qi-rm {
      flex-shrink: 0;
      background: none;
      border: none;
      cursor: pointer;
      color: var(--text-muted);
      padding: 0.25rem;
      border-radius: 4px;
      display: flex;
      align-items: center;
      opacity: 0;
      transition: opacity 0.1s, color 0.1s;
    }
    .qi:hover .qi-rm { opacity: 1; }
    .qi-rm:hover { color: var(--danger); }

    /* ---- Add form ---- */
    #add-form {
      padding: 0.75rem;
      border-top: 1px solid var(--border);
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
      flex-shrink: 0;
    }

    #url-in {
      width: 100%;
      background: var(--bg);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      color: var(--text);
      padding: 0.5rem 0.75rem;
      font-size: 0.875rem;
      font-family: var(--font);
      outline: none;
      transition: border-color 0.15s;
    }
    #url-in:focus { border-color: var(--accent-light); }
    #url-in::placeholder { color: var(--text-muted); }

    #add-btn {
      width: 100%;
      background: var(--accent);
      color: #fff;
      border: none;
      border-radius: var(--radius);
      padding: 0.5rem;
      font-size: 0.875rem;
      font-weight: 600;
      cursor: pointer;
      font-family: var(--font);
      transition: background 0.15s;
    }
    #add-btn:hover { background: var(--accent-light); }
    #add-btn:disabled { opacity: 0.5; cursor: not-allowed; }

    /* ---- Toast ---- */
    #toast {
      position: fixed;
      bottom: 1.5rem;
      left: 50%;
      transform: translateX(-50%) translateY(4rem);
      background: var(--bg-surface);
      border: 1px solid var(--border);
      color: var(--text);
      padding: 0.625rem 1.125rem;
      border-radius: var(--radius);
      font-size: 0.875rem;
      z-index: 50;
      transition: transform 0.2s ease;
      pointer-events: none;
      white-space: nowrap;
    }
    #toast.show { transform: translateX(-50%) translateY(0); }

    /* ---- Scrollbars ---- */
    ::-webkit-scrollbar { width: 4px; }
    ::-webkit-scrollbar-track { background: transparent; }
    ::-webkit-scrollbar-thumb { background: var(--border); border-radius: 99px; }

    /* ---- Mobile ---- */
    @media (max-width: 700px) {
      #body { flex-direction: column; height: auto; min-height: calc(100vh - var(--header)); overflow-y: auto; }
      #player-area { overflow-y: visible; }
      #sidebar { width: 100%; border-left: none; border-top: 1px solid var(--border); max-height: 55vh; }
      #uname { max-width: 60px; }
    }
  </style>
</head>
<body>

  <header id="hdr">
    <div id="hdr-left">
      <a id="hdr-back" href="/" title="Back to home">&larr;</a>
      <span id="hdr-room">{roomName}</span>
    </div>
    <div id="hdr-right">
      <span id="conn" class="connecting">Connecting</span>
      <span id="uc">1 viewer</span>
      <span id="uname" title="Click to change name">Guest</span>
    </div>
  </header>

  <div id="body">
    <section id="player-area">
      <div id="player-wrap">
        <div id="yt-player"></div>
        <div id="placeholder">
          <svg width="52" height="52" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2">
            <circle cx="12" cy="12" r="10"/>
            <polygon points="10,8 16,12 10,16"/>
          </svg>
          <span>Add a video to start watching</span>
        </div>
      </div>
      <div id="nowplay">Nothing playing</div>
    </section>

    <aside id="sidebar">
      <div id="q-header">Queue</div>
      <ul id="q-list"></ul>
      <form id="add-form">
        <input id="url-in" type="url" placeholder="Paste YouTube URL..." autocomplete="off" spellcheck="false" />
        <button id="add-btn" type="submit">Add to Queue</button>
      </form>
    </aside>
  </div>

  <div id="toast"></div>

  <script define:vars={{ roomName }}>
    // ============================================================
    // PartyPlayback — Room Client
    // roomName is injected server-side via define:vars
    // ============================================================

    const DESYNC = 1.5; // seconds — ignore drifts smaller than this

    // State
    let ws = null;
    let player = null;
    let playerReady = false;
    let isSyncing = false;
    let syncTimer = null;
    let pendingState = null; // {videoId, targetTime, shouldPlay} — queued before player ready
    let lastVideoId = null;
    let queue = [];
    let currentIndex = -1;
    let isPlaying = false;
    let reconnTimer = null;
    let reconnDelay = 1000;

    // DOM
    const $conn    = document.getElementById('conn');
    const $uc      = document.getElementById('uc');
    const $uname   = document.getElementById('uname');
    const $qlist   = document.getElementById('q-list');
    const $form    = document.getElementById('add-form');
    const $urlin   = document.getElementById('url-in');
    const $addbtn  = document.getElementById('add-btn');
    const $nowplay = document.getElementById('nowplay');
    const $ph      = document.getElementById('placeholder');
    const $toast   = document.getElementById('toast');

    // ---- Username ----
    function getUser() {
      let u = localStorage.getItem('pp_user');
      if (!u) { u = 'Guest' + (Math.random() * 9000 + 1000 | 0); localStorage.setItem('pp_user', u); }
      return u;
    }
    function setUser(u) { localStorage.setItem('pp_user', u); $uname.textContent = u; }
    function getSid() {
      let s = sessionStorage.getItem('pp_sid');
      if (!s) { s = crypto.randomUUID(); sessionStorage.setItem('pp_sid', s); }
      return s;
    }

    $uname.textContent = getUser();
    $uname.addEventListener('click', () => {
      const n = prompt('Display name:', getUser());
      if (n && n.trim()) {
        setUser(n.trim().slice(0, 32));
        send({ type: 'join', username: getUser(), sessionId: getSid() });
      }
    });

    // ---- Toast ----
    let toastT = null;
    function toast(msg, ms = 3500) {
      $toast.textContent = msg;
      $toast.classList.add('show');
      clearTimeout(toastT);
      toastT = setTimeout(() => $toast.classList.remove('show'), ms);
    }

    // ---- WebSocket ----
    function connect() {
      if (ws && ws.readyState < 2) return; // OPEN or CONNECTING
      const proto = location.protocol === 'https:' ? 'wss:' : 'ws:';
      ws = new WebSocket(proto + '//' + location.host + '/api/ws/' + roomName);
      setConn('connecting');

      ws.addEventListener('open', () => {
        setConn('connected');
        reconnDelay = 1000;
        send({ type: 'join', username: getUser(), sessionId: getSid() });
      });

      ws.addEventListener('message', (e) => {
        let d; try { d = JSON.parse(e.data); } catch { return; }
        onMsg(d);
      });

      ws.addEventListener('close', () => { setConn('disconnected'); schedReconn(); });
      ws.addEventListener('error', () => setConn('disconnected'));
    }

    function schedReconn() {
      clearTimeout(reconnTimer);
      reconnTimer = setTimeout(() => { reconnDelay = Math.min(reconnDelay * 2, 30000); connect(); }, reconnDelay);
    }

    function send(obj) {
      if (ws && ws.readyState === 1) ws.send(JSON.stringify(obj));
    }

    function setConn(s) {
      $conn.className = s;
      $conn.textContent = s === 'connected' ? 'Live' : s === 'connecting' ? 'Connecting' : 'Reconnecting…';
    }

    // ---- Message handler ----
    function onMsg(d) {
      switch (d.type) {
        case 'state':
          queue = d.queue || [];
          currentIndex = d.currentIndex ?? -1;
          isPlaying = d.isPlaying ?? false;
          renderQ();
          renderNow();
          applyState(d.currentTime || 0, d.isPlaying);
          if (d.userCount != null) setUC(d.userCount);
          break;

        case 'queue':
          queue = d.queue || [];
          currentIndex = d.currentIndex ?? -1;
          if (typeof d.isPlaying === 'boolean') isPlaying = d.isPlaying;
          renderQ();
          renderNow();
          applyState(d.currentTime || 0, d.isPlaying ?? isPlaying);
          break;

        case 'play':
          isPlaying = true;
          remote(() => {
            if (playerReady && Math.abs(player.getCurrentTime() - d.currentTime) > DESYNC)
              player.seekTo(d.currentTime, true);
            player.playVideo();
          });
          break;

        case 'pause':
          isPlaying = false;
          remote(() => {
            if (playerReady && Math.abs(player.getCurrentTime() - d.currentTime) > DESYNC)
              player.seekTo(d.currentTime, true);
            player.pauseVideo();
          });
          break;

        case 'seek':
          remote(() => player.seekTo(d.currentTime, true));
          break;

        case 'users':
          setUC(d.userCount);
          break;

        case 'ended':
          isPlaying = false;
          renderNow();
          break;
      }
    }

    // Load/sync the player to a given state (called on 'state' and 'queue' messages)
    function applyState(targetTime, shouldPlay) {
      if (currentIndex < 0 || currentIndex >= queue.length) {
        showPH(true);
        return;
      }
      const videoId = queue[currentIndex].videoId;

      if (!playerReady) {
        pendingState = { videoId, targetTime, shouldPlay };
        return;
      }

      showPH(false);

      if (lastVideoId !== videoId) {
        lastVideoId = videoId;
        remote(() => {
          if (shouldPlay) {
            player.loadVideoById({ videoId, startSeconds: targetTime });
          } else {
            // cueVideoById loads without auto-playing (avoids the loadVideoById auto-play quirk)
            player.cueVideoById({ videoId, startSeconds: targetTime });
          }
        });
      } else {
        // Same video — just sync time/play state
        remote(() => {
          if (Math.abs(player.getCurrentTime() - targetTime) > DESYNC)
            player.seekTo(targetTime, true);
          if (shouldPlay) player.playVideo();
          else player.pauseVideo();
        });
      }
    }

    // Wrap player commands with isSyncing to suppress echoed events
    function remote(fn) {
      if (!playerReady) return;
      isSyncing = true;
      clearTimeout(syncTimer);
      fn();
      // 800ms covers seekTo → BUFFERING → PLAYING event chain on slow connections
      syncTimer = setTimeout(() => { isSyncing = false; }, 800);
    }

    function showPH(yes) { $ph.style.display = yes ? 'flex' : 'none'; }
    function setUC(n) { $uc.textContent = n + ' viewer' + (n !== 1 ? 's' : ''); }

    // ---- YouTube IFrame API ----
    // Called by the YT script when it's loaded and ready
    window.onYouTubeIframeAPIReady = function () {
      player = new YT.Player('yt-player', {
        height: '100%',
        width: '100%',
        playerVars: { controls: 1, modestbranding: 1, rel: 0, enablejsapi: 1 },
        events: {
          onReady() {
            playerReady = true;
            if (pendingState) {
              const ps = pendingState;
              pendingState = null;
              showPH(false);
              applyState(ps.targetTime, ps.shouldPlay);
            }
          },
          onStateChange(evt) {
            if (isSyncing) return; // Suppress events triggered by remote commands
            if (evt.data === YT.PlayerState.PLAYING) {
              send({ type: 'play', currentTime: player.getCurrentTime() });
            } else if (evt.data === YT.PlayerState.PAUSED) {
              send({ type: 'pause', currentTime: player.getCurrentTime() });
            } else if (evt.data === YT.PlayerState.ENDED) {
              send({ type: 'next' });
            }
          },
          onError() {
            toast('Video unavailable or embedding not allowed — skipping');
            send({ type: 'next' });
          },
        },
      });
    };

    // ---- Queue rendering ----
    function renderQ() {
      $qlist.innerHTML = '';
      queue.forEach((item, i) => {
        const li = document.createElement('li');
        li.className = 'qi' + (i === currentIndex ? ' now' : '');

        const img = document.createElement('img');
        img.className = 'qi-thumb';
        img.src = 'https://img.youtube.com/vi/' + item.videoId + '/mqdefault.jpg';
        img.alt = '';
        img.loading = 'lazy';

        const info = document.createElement('div');
        info.className = 'qi-info';
        const t = document.createElement('div');
        t.className = 'qi-title';
        t.textContent = item.title;
        const s = document.createElement('div');
        s.className = 'qi-sub';
        s.textContent = i === currentIndex ? 'Now playing' : '#' + (i + 1);
        info.append(t, s);

        const rm = document.createElement('button');
        rm.className = 'qi-rm';
        rm.title = 'Remove';
        rm.innerHTML = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>';
        rm.addEventListener('click', () => send({ type: 'remove', index: i }));

        li.append(img, info, rm);
        $qlist.appendChild(li);
      });
    }

    function renderNow() {
      if (currentIndex >= 0 && currentIndex < queue.length) {
        $nowplay.innerHTML = 'Now playing: <b>' + esc(queue[currentIndex].title) + '</b>';
      } else {
        $nowplay.textContent = 'Nothing playing';
      }
    }

    function esc(s) {
      return s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
    }

    // ---- Add form ----
    $form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const url = $urlin.value.trim();
      if (!url) return;
      if (!url.includes('youtube.com') && !url.includes('youtu.be')) {
        toast('Please paste a YouTube URL');
        return;
      }
      $addbtn.disabled = true;
      $addbtn.textContent = 'Loading…';
      let title = url;
      try {
        const r = await fetch('https://www.youtube.com/oembed?url=' + encodeURIComponent(url) + '&format=json');
        if (r.ok) title = (await r.json()).title || url;
      } catch {}
      send({ type: 'add', url, title });
      $urlin.value = '';
      $addbtn.disabled = false;
      $addbtn.textContent = 'Add to Queue';
    });

    // ---- Boot ----
    connect();

    // Load YouTube IFrame API asynchronously
    const yt = document.createElement('script');
    yt.src = 'https://www.youtube.com/iframe_api';
    document.head.appendChild(yt);
  </script>
</body>
</html>
